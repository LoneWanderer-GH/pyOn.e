# Configuration One BLE Daemon — Raspberry Pi
# Copié vers /etc/one/daemon.env par install_one_raspi.sh
# Modifier puis : sudo systemctl restart one-daemon

# Adresse BLE du module One (utilisée si ONE_CONFIG absent ou incomplet)
ONE_ADDRESS=E7:4A:DB:3B:62:E5

# Ports ZeroMQ (ne pas modifier sauf conflit)
ONE_PUB_PORT=5560
ONE_CMD_PORT=5561

# Chemin de la config JSON persistant la shared_key (créée par --pair-only)
ONE_CONFIG=/etc/one/one_daemon.json

# Intervalle de polling en secondes
ONE_POLL_INTERVAL=5.0

# Niveau de log : DEBUG | INFO | WARNING | ERROR
ONE_LOG_LEVEL=INFO
